{
  "version": 2,
  "builds": [
    {
      "src": "sample_project/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "sample_project/wsgi.py"
    }
  ]
}
